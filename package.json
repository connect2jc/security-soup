{
  "name": "securesecrets-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/engine",
    "packages/cli",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build:engine && npm run build:cli && npm run build:web && npm run bundle",
    "build:engine": "npm run build -w packages/engine",
    "build:cli": "npm run build -w packages/cli",
    "build:web": "npm run build -w packages/web",
    "bundle": "cp -r packages/web/dist packages/cli/web-dist",
    "dev": "npm run build:engine && npm run build:cli && node packages/cli/dist/index.js serve --no-open",
    "test": "npm test -w packages/engine"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
